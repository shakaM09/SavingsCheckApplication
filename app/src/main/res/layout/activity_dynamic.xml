<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".DynamicActivity"
    android:orientation="vertical"
    android:padding="20dp">

  <EditText android:id="@+id/etName" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Saving Name" />
  <EditText android:id="@+id/etAmount" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Initial Money" android:inputType="numberDecimal" />
  <ImageView
      android:id="@+id/ivCameraPreview"
      android:layout_width="150dp"
      android:layout_height="150dp"
      android:layout_gravity="center"
      android:src="@android:drawable/ic_menu_camera"
      android:scaleType="centerCrop" />

  <Button
      android:id="@+id/btnLaunchCamera"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="pick a picture" />
  <Button android:id="@+id/btnSave" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Create" />
</LinearLayout>